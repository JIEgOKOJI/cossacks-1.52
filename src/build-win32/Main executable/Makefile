	cd /Users/ildarkarimov/Documents/cossacks-1.52/src/build-win32 && $(MAKE) $(MAKESILENT) -f "Main executable/CMakeFiles/dmcr.dir/build.make" "Main executable/CMakeFiles/dmcr.dir/walls.cpp.obj"
.PHONY : walls.cpp.obj

walls.i: walls.cpp.i
.PHONY : walls.i

# target to preprocess a source file
walls.cpp.i:
	cd /Users/ildarkarimov/Documents/cossacks-1.52/src/build-win32 && $(MAKE) $(MAKESILENT) -f "Main executable/CMakeFiles/dmcr.dir/build.make" "Main executable/CMakeFiles/dmcr.dir/walls.cpp.i"
.PHONY : walls.cpp.i

walls.s: walls.cpp.s
.PHONY : walls.s

# target to generate assembly for a file
walls.cpp.s:
	cd /Users/ildarkarimov/Documents/cossacks-1.52/src/build-win32 && $(MAKE) $(MAKESILENT) -f "Main executable/CMakeFiles/dmcr.dir/build.make" "Main executable/CMakeFiles/dmcr.dir/walls.cpp.s"
.PHONY : walls.cpp.s

